.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.loading-mask {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
  font-size: 28rpx;
  color: #999;
}

.section {
  background: white;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #FF6B9D;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.stats-grid-3 {
  margin-top: 16rpx;
}

.stat-card {
  flex: 1;
  min-width: 140rpx;
  background: linear-gradient(135deg, #FFF0F5, #FFE4EC);
  border-radius: 12rpx;
  padding: 20rpx 12rpx;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #FF6B9D;
  margin-bottom: 6rpx;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.stat-card-sm {
  flex: 1;
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 16rpx 12rpx;
  text-align: center;
}

.stat-value-sm {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.chart-container {
  width: 100%;
  height: 400rpx;
  position: relative;
}

.chart-canvas {
  width: 100%;
  height: 100%;
}
