.page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 40rpx;
}

/* ====== 头部 ====== */
.hero-section {
  text-align: center;
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #FDF2F8 0%, #F3F0FF 50%, #EFF6FF 100%);
  margin-bottom: 24rpx;
}

.hero-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FF6B9D, #A78BFA, #60A5FA);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block;
  letter-spacing: 2rpx;
}

.hero-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 10rpx;
  display: block;
}

.ai-badge-row {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.ai-badge {
  font-size: 20rpx;
  color: var(--secondary);
  background: rgba(167, 139, 250, 0.12);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

/* ====== 列表头部 ====== */
.list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx 20rpx;
}

.list-count {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.highlight {
  color: var(--primary);
  font-weight: 700;
}

.match-legend {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.legend-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin: 0 2rpx 0 12rpx;
}

.legend-dot.high { background: #34D399; }
.legend-dot.mid { background: #FBBF24; }
.legend-dot.low { background: #F87171; }

.legend-text {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

/* ====== 推荐卡片 ====== */
.recommend-list {
  padding: 0 28rpx;
}

.recommend-card {
  display: flex;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1),
              box-shadow 0.2s ease;
  gap: 20rpx;
}

.card-hover {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(167, 139, 250, 0.15);
}

/* -- 匹配度环 -- */
.match-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-width: 100rpx;
}

.match-label {
  font-size: 18rpx;
  font-weight: 600;
  text-align: center;
  line-height: 1.2;
}

.match-ring {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
}

.match-ring::before {
  content: '';
  position: absolute;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #fff;
}

.match-score {
  font-size: 22rpx;
  font-weight: 800;
  color: var(--primary);
  z-index: 1;
}

/* -- 卡片主体 -- */
.card-main {
  flex: 1;
  min-width: 0;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.card-user {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.user-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.user-avatar text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 700;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 24rpx;
  color: var(--text);
  font-weight: 600;
}

.match-tag {
  font-size: 18rpx;
  color: #34D399;
  font-weight: 600;
}

.match-tag.mid {
  color: #FBBF24;
}

/* -- 状态徽章 -- */
.status-badge {
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.status-0 { background: #ECFDF5; color: #34D399; }
.status-1 { background: #FFFBEB; color: #FBBF24; }
.status-2 { background: #EFF6FF; color: #60A5FA; }

/* -- 标题 -- */
.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 10rpx;
}

/* -- 标签 -- */
.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 14rpx;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}
.tag-goods { background: #FDF2F8; color: #FF6B9D; }
.tag-dist { background: #F3F0FF; color: #A78BFA; }

/* -- 进度条 -- */
.card-progress {
  background: var(--bg);
  border-radius: var(--radius-sm);
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.progress-label {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.progress-num {
  font-size: 22rpx;
  color: var(--secondary);
  font-weight: 600;
}

.progress-track {
  height: 8rpx;
  background: var(--border);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B9D, #A78BFA);
  border-radius: 4rpx;
  transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* -- 底部 -- */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 700;
}

.price-amount {
  font-size: 36rpx;
  color: var(--primary);
  font-weight: 800;
  line-height: 1;
  margin: 0 2rpx;
}

.price-unit {
  font-size: 20rpx;
  color: var(--primary);
}

.card-action {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #FF6B9D, #A78BFA);
  border-radius: 28rpx;
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 157, 0.25);
}

.action-arrow {
  font-size: 20rpx;
}

/* ====== 空状态 ====== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}

.empty-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #F3F0FF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.empty-icon {
  font-size: 64rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--text-tertiary);
  text-align: center;
  margin-bottom: 36rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #FF6B9D, #A78BFA);
  color: #fff;
  padding: 22rpx 72rpx;
  border-radius: var(--radius-xl);
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 157, 0.3);
}

/* ====== 骨架屏 ====== */
.skeleton-list { padding: 0 28rpx; }

.skeleton-card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.skeleton {
  background: linear-gradient(90deg, #F3F0FF 25%, #FDF2F8 50%, #F3F0FF 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: var(--radius-sm);
}

.skeleton-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  background: none;
  animation: none;
}

.skeleton-avatar { width: 48rpx; height: 48rpx; border-radius: 50%; }
.skeleton-name { flex: 1; height: 28rpx; }
.skeleton-badge { width: 72rpx; height: 28rpx; border-radius: 14rpx; }
.skeleton-title { height: 30rpx; width: 60%; margin-bottom: 16rpx; }
.skeleton-progress { height: 80rpx; margin-bottom: 16rpx; }
.skeleton-footer { display: flex; justify-content: space-between; background: none; animation: none; }
.skeleton-price { width: 100rpx; height: 36rpx; }
.skeleton-btn { width: 100rpx; height: 48rpx; border-radius: 24rpx; }

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ====== 底部 ====== */
.load-more {
  padding: 32rpx 0;
}

.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 32rpx;
  gap: 20rpx;
}

.no-more-line {
  flex: 1;
  height: 2rpx;
  background: var(--border);
}

.no-more-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
}
