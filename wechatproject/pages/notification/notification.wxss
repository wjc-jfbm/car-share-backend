.container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 20rpx;
}

/* ====== 头部 ====== */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: var(--bg-card);
  border-bottom: 2rpx solid var(--border);
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.header-icon {
  font-size: 32rpx;
}

.unread-info {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 700;
}

.mark-all {
  font-size: 24rpx;
  color: var(--primary);
  padding: 10rpx 24rpx;
  background: #FDF2F8;
  border-radius: 24rpx;
  font-weight: 500;
}

.mark-all:active {
  transform: scale(0.95);
}

/* ====== 通知列表 ====== */
.notification-list {
  padding: 0 24rpx;
}

.notification-item {
  display: flex;
  align-items: flex-start;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-top: 16rpx;
  box-shadow: var(--shadow-sm);
  transition: transform 0.15s;
}

.notification-item:active {
  transform: scale(0.98);
}

.notification-item.unread {
  background: linear-gradient(135deg, #FFF5F8, #FFF);
  border-left: 6rpx solid var(--primary);
}

.notification-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--primary);
  margin-top: 14rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  box-shadow: 0 0 8rpx rgba(255, 107, 157, 0.4);
}

.notification-content {
  flex: 1;
  min-width: 0;
}

.notification-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.notification-type {
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, var(--primary), var(--secondary));
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.notification-type.type-success {
  background: linear-gradient(135deg, #34D399, #6EE7B7);
}

.notification-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.notification-title {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 700;
  display: block;
  margin-bottom: 6rpx;
}

.notification-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.notification-actions {
  margin-left: 16rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.action-delete {
  font-size: 22rpx;
  color: var(--text-tertiary);
  padding: 8rpx 16rpx;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
}

.action-delete:active {
  background: #FEF2F2;
  color: var(--danger);
  border-color: var(--danger);
}

/* ====== 空状态 ====== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 88rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.loading-more, .no-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
  color: var(--text-tertiary);
}
