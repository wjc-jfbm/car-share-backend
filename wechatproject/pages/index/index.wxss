.page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 140rpx;
}

/* ====== 头部渐变区域 ====== */
.header {
  position: relative;
  padding-top: 0;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #A78BFA 50%, #60A5FA 100%);
  border-radius: 0 0 56rpx 56rpx;
}

.header-content {
  position: relative;
  z-index: 2;
  padding: 24rpx 32rpx 32rpx;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.header-greeting {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.3;
}

.header-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 4rpx;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.header-icon-btn {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  backdrop-filter: blur(10px);
}

.header-icon {
  width: 36rpx;
  height: 36rpx;
}

.unread-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: linear-gradient(135deg, #FF6B9D, #F87171);
  border-radius: 16rpx;
  font-size: 18rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  font-weight: 700;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 157, 0.4);
}

.header-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10px);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 700;
}

.search-bar {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  padding: 0 28rpx;
  height: 76rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  backdrop-filter: blur(20px);
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 76rpx;
  font-size: 28rpx;
  color: #333;
  margin-left: 16rpx;
}

.search-placeholder {
  color: #aaa;
  font-size: 28rpx;
}

.search-clear {
  padding: 12rpx;
}

.clear-icon {
  font-size: 24rpx;
  color: #ccc;
  font-weight: 300;
}

.main-scroll {
  height: calc(100vh - 240rpx);
}

.banner-section {
  padding: 24rpx 32rpx 0;
}

.banner-swiper {
  height: 200rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-card {
  height: 200rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 48rpx;
  position: relative;
  overflow: hidden;
}

.banner-card::after {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.banner-1 {
  background: linear-gradient(135deg, #FF6B9D 0%, #A78BFA 100%);
}

.banner-2 {
  background: linear-gradient(135deg, #60A5FA 0%, #34D399 100%);
}

.banner-3 {
  background: linear-gradient(135deg, #FBBF24 0%, #FF6B9D 100%);
}

.banner-text-wrap {
  display: flex;
  flex-direction: column;
  z-index: 1;
}

.banner-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.3;
}

.banner-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

.banner-emoji {
  font-size: 72rpx;
  z-index: 1;
}

.banner-icon {
  width: 80rpx;
  height: 80rpx;
  z-index: 1;
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 24rpx 24rpx;
  margin: 0 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  margin-top: 24rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.quick-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qi-1 {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FAB 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 157, 0.3);
}

.qi-2 {
  background: linear-gradient(135deg, #A78BFA 0%, #C4B5FD 100%);
  box-shadow: 0 4rpx 16rpx rgba(167, 139, 250, 0.3);
}

.qi-3 {
  background: linear-gradient(135deg, #60A5FA 0%, #93C5FD 100%);
  box-shadow: 0 4rpx 16rpx rgba(96, 165, 250, 0.3);
}

.qi-4 {
  background: linear-gradient(135deg, #34D399 0%, #6EE7B7 100%);
  box-shadow: 0 4rpx 16rpx rgba(52, 211, 153, 0.3);
}

.quick-emoji {
  font-size: 40rpx;
  line-height: 1;
}

.quick-img {
  width: 44rpx;
  height: 44rpx;
}

.quick-label {
  font-size: 22rpx;
  color: #555;
  font-weight: 500;
}

.platform-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin: 24rpx 32rpx 0;
  padding: 28rpx 16rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FF6B9D, #A78BFA);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #eee;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 32rpx 16rpx;
}

.section-title-wrap {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #222;
}

.section-sub {
  font-size: 24rpx;
  color: #aaa;
}

.filter-bar {
  padding: 0 32rpx 16rpx;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  background: #fff;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  transition: all 0.2s;
}

.filter-chip text {
  font-size: 26rpx;
}

.chip-active {
  background: linear-gradient(135deg, #FF6B9D 0%, #A78BFA 100%);
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 157, 0.3);
}

/* ====== 筛选排序面板 ====== */
.filter-sort-btn {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 24rpx;
  border-radius: 28rpx;
  background: var(--bg-card);
  font-size: 24rpx;
  color: var(--text-secondary);
  box-shadow: var(--shadow-sm);
  margin-left: auto;
  position: relative;
}

.filter-dot {
  color: var(--primary);
  font-size: 20rpx;
  position: absolute;
  top: 4rpx;
  right: 8rpx;
}

.filter-panel {
  background: var(--bg-card);
  margin: 0 28rpx 16rpx;
  border-radius: var(--radius-md);
  padding: 24rpx;
  box-shadow: var(--shadow-md);
  animation: slideDown 0.2s ease;
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.filter-section {
  margin-bottom: 20rpx;
}

.filter-section:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
  font-weight: 600;
}

.sort-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.sort-chip {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  background: var(--bg);
  color: var(--text-secondary);
  border: 2rpx solid var(--border);
}

.sort-chip.active {
  background: #FDF2F8;
  color: var(--primary);
  border-color: var(--primary);
  font-weight: 600;
}

.price-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.price-input {
  flex: 1;
  height: 64rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
  padding: 0 16rpx;
  font-size: 26rpx;
  color: var(--text);
  border: 2rpx solid var(--border);
}

.price-sep {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.price-btn {
  padding: 14rpx 28rpx;
  background: linear-gradient(135deg, #FF6B9D, #A78BFA);
  color: #fff;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.filter-actions {
  display: flex;
  justify-content: flex-end;
  padding-top: 12rpx;
  border-top: 2rpx solid var(--border);
}

.filter-reset {
  font-size: 24rpx;
  color: var(--text-tertiary);
  padding: 8rpx 20rpx;
}

.chip-active text {
  color: #fff;
}

.car-list {
  padding: 0 32rpx;
}

.car-card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1),
              box-shadow 0.2s ease;
}

.car-card-hover {
  transform: scale(0.98);
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.card-user {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.user-avatar text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 700;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.user-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.user-time {
  font-size: 22rpx;
  color: #bbb;
}

.status-badge {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-badge text {
  font-size: 22rpx;
}

.status-0 {
  background: rgba(102, 126, 234, 0.12);
  color: #667eea;
}

.status-0 text {
  color: #667eea;
}

.status-1 {
  background: rgba(255, 165, 0, 0.12);
  color: #ffa500;
}

.status-1 text {
  color: #ffa500;
}

.status-2 {
  background: rgba(67, 233, 123, 0.12);
  color: #2ecc71;
}

.status-2 text {
  color: #2ecc71;
}

.status-3 {
  background: rgba(46, 204, 113, 0.12);
  color: #27ae60;
}

.status-3 text {
  color: #27ae60;
}

.status-4 {
  background: rgba(170, 170, 170, 0.12);
  color: #aaa;
}

.status-4 text {
  color: #aaa;
}

.card-body {
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.tag-goods {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
}

.tag-dist {
  background: rgba(240, 147, 251, 0.1);
  color: #d63384;
}

.tag-credit {
  background: rgba(255, 165, 0, 0.1);
  color: #e67e22;
}

.card-progress-section {
  background: #f8f9fc;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.progress-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.progress-label {
  font-size: 22rpx;
  color: #888;
}

.progress-num {
  font-size: 24rpx;
  color: #667eea;
  font-weight: 600;
}

.progress-track {
  height: 12rpx;
  background: #e8eaf0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B9D, #A78BFA);
  border-radius: 6rpx;
  transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.progress-footer {
  margin-top: 10rpx;
}

.success-rate {
  font-size: 22rpx;
  color: #43e97b;
  font-weight: 500;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-footer-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-fav {
  font-size: 36rpx;
  padding: 8rpx;
  transition: transform 0.2s;
}

.card-fav:active {
  transform: scale(0.8);
}

.fav-active {
  animation: heartBeat 0.3s ease;
}

@keyframes heartBeat {
  0% { transform: scale(1); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

.card-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #f5576c;
  font-weight: 700;
}

.price-amount {
  font-size: 44rpx;
  color: #f5576c;
  font-weight: 700;
  line-height: 1;
  margin: 0 2rpx;
}

.price-unit {
  font-size: 22rpx;
  color: #f5576c;
}

.card-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #A78BFA 100%);
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 157, 0.25);
}

.action-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

.action-arrow {
  font-size: 24rpx;
  color: #fff;
}

.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 32rpx;
  color: #666;
  font-weight: 600;
}

.error-hint {
  font-size: 24rpx;
  color: #aaa;
  margin-top: 12rpx;
}

.error-btn {
  margin-top: 40rpx;
  background: var(--bg-card);
  color: var(--primary);
  font-size: 28rpx;
  padding: 22rpx 72rpx;
  border-radius: var(--radius-xl);
  font-weight: 600;
  border: 2rpx solid var(--primary);
}

.empty-icon-area {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f0f2ff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-icon {
  font-size: 56rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-img {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  font-weight: 600;
}

.empty-hint {
  font-size: 24rpx;
  color: #aaa;
  margin-top: 12rpx;
}

.empty-btn {
  margin-top: 40rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #A78BFA 100%);
  color: #fff;
  font-size: 28rpx;
  padding: 22rpx 72rpx;
  border-radius: var(--radius-xl);
  font-weight: 600;
  box-shadow: 0 6rpx 28rpx rgba(255, 107, 157, 0.35);
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #667eea;
  animation: dotBounce 1.2s ease-in-out infinite;
}

.dot-2 {
  animation-delay: 0.2s;
}

.dot-3 {
  animation-delay: 0.4s;
}

@keyframes dotBounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

.loading-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 32rpx;
  gap: 20rpx;
}

.no-more-line {
  flex: 1;
  height: 1rpx;
  background: #e0e0e0;
}

.no-more-text {
  font-size: 22rpx;
  color: #ccc;
}

.fab-btn {
  position: fixed;
  right: 36rpx;
  bottom: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #A78BFA 100%);
  border-radius: 50%;
  box-shadow: 0 8rpx 36rpx rgba(255, 107, 157, 0.45);
  z-index: 100;
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1),
              box-shadow 0.2s ease;
}

.fab-hover {
  transform: scale(0.9);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

/* ====== 骨架屏 ====== */
.skeleton-section {
  padding: 0 32rpx;
}

.skeleton-banner {
  height: 180rpx;
  background: linear-gradient(90deg, #F3F0FF 25%, #FDF2F8 50%, #F3F0FF 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: var(--radius-md);
  margin: 24rpx 0;
}

.skeleton-actions {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 16rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

.skeleton-action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.skeleton-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
}

.skeleton-stats {
  display: flex;
  justify-content: space-around;
  padding: 28rpx 16rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

.skeleton-stat {
  width: 80rpx;
  height: 60rpx;
  border-radius: var(--radius-sm);
}

.skeleton-filter {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.skeleton-chip {
  width: 100rpx;
  height: 56rpx;
  border-radius: 28rpx;
}

.skeleton-card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.skeleton-card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
}

.skeleton-card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.skeleton-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.skeleton-card-user {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.skeleton-text {
  height: 24rpx;
  background: linear-gradient(90deg, #F3F0FF 25%, #FDF2F8 50%, #F3F0FF 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: 12rpx;
}

.skeleton-text-short { width: 120rpx; }
.skeleton-text-name { width: 140rpx; height: 28rpx; }
.skeleton-text-time { width: 100rpx; height: 20rpx; }
.skeleton-text-title { width: 70%; height: 28rpx; margin-bottom: 12rpx; }
.skeleton-text-desc { width: 50%; height: 22rpx; margin-bottom: 20rpx; }
.skeleton-text-small { width: 80rpx; height: 20rpx; }
.skeleton-text-price { width: 120rpx; height: 36rpx; }

.skeleton-badge {
  width: 80rpx;
  height: 36rpx;
  border-radius: 18rpx;
}

.skeleton-card-progress {
  padding: 20rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
  margin-bottom: 20rpx;
}

.skeleton-progress-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.skeleton-progress-bar {
  height: 12rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #F3F0FF 25%, #FDF2F8 50%, #F3F0FF 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
}

.skeleton-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.skeleton-btn {
  width: 120rpx;
  height: 56rpx;
  border-radius: 28rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.fab-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

.fab-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 2rpx;
}
