.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.settle-header {
  background: linear-gradient(135deg, #FF6B9D, #FF8FA3);
  padding: 32rpx 24rpx;
  color: white;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
}

.header-amount {
  font-size: 44rpx;
  font-weight: bold;
  color: white;
}

.header-stats {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 20rpx 0;
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: white;
}

.stat-value.green {
  color: #c8e6c9;
}

.stat-value.orange {
  color: #ffe0b2;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.section {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 16rpx 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.member-evidence-list {
  margin-top: 8rpx;
}

.member-evidence-card {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.member-evidence-card:last-child {
  margin-bottom: 0;
}

.member-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B9D, #FF8FA3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.member-avatar text {
  font-size: 26rpx;
  color: white;
  font-weight: bold;
}

.member-info {
  flex: 1;
}

.member-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.member-amount {
  display: block;
  font-size: 24rpx;
  color: #FF6B9D;
  margin-top: 4rpx;
}

.member-status-group {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.status-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.evidence-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
  padding: 12rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  position: relative;
}

.evidence-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
}

.evidence-view-hint {
  position: absolute;
  bottom: 8rpx;
  right: 12rpx;
  font-size: 20rpx;
  color: #999;
  background: rgba(255, 255, 255, 0.9);
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

.reject-reason {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background: #fff3e0;
  border-radius: 8rpx;
  border-left: 6rpx solid #FF9800;
}

.reject-label {
  font-size: 24rpx;
  color: #FF9800;
  font-weight: bold;
}

.reject-text {
  font-size: 24rpx;
  color: #666;
  margin-left: 8rpx;
}

.review-action {
  margin-top: 16rpx;
}

.btn-review {
  width: 100%;
  height: 64rpx;
  line-height: 64rpx;
  background: linear-gradient(135deg, #FF6B9D, #FF8FA3);
  color: white;
  font-size: 26rpx;
  border-radius: 32rpx;
  border: none;
}

.upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.upload-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.upload-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.upload-remove {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-icon {
  font-size: 20rpx;
  color: white;
}

.upload-add {
  width: 160rpx;
  height: 160rpx;
  border: 4rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.add-icon {
  font-size: 48rpx;
  color: #ccc;
  line-height: 1;
}

.add-text {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}

.upload-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 16rpx;
  margin-bottom: 20rpx;
}

.btn-primary {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #FF6B9D, #FF8FA3);
  color: white;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.tag-pink {
  background: #fce4ec;
  color: #FF6B9D;
}

.btn-primary[disabled] {
  background: #ddd;
  color: #999;
}

.owner-actions {
  padding: 16rpx 0;
}

.btn-settle {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: white;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
}

.ship-section {
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
  border: 2rpx solid #2196F3;
}

.ship-notice {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.ship-notice-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.ship-notice-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #1565C0;
}

.btn-ship-go {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #2196F3, #42A5F5);
  color: white;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  margin-bottom: 12rpx;
}

.settle-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.modal-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  z-index: 201;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx;
}

.modal-body {
  margin-bottom: 24rpx;
}

.review-member {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.review-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.review-amount {
  font-size: 32rpx;
  color: #FF6B9D;
  font-weight: bold;
}

.review-evidence-preview {
  margin-bottom: 20rpx;
}

.review-image {
  width: 100%;
  max-height: 400rpx;
  border-radius: 12rpx;
}

.review-options {
  display: flex;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.review-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
  border-radius: 12rpx;
  background: #f5f5f5;
  border: 2rpx solid transparent;
}

.review-option.selected.approve {
  background: #e8f5e9;
  border-color: #4CAF50;
}

.review-option.selected.reject {
  background: #ffebee;
  border-color: #F44336;
}

.review-option-icon {
  font-size: 32rpx;
}

.review-option.selected.approve .review-option-icon {
  color: #4CAF50;
}

.review-option.selected.reject .review-option-icon {
  color: #F44336;
}

.review-option-text {
  font-size: 28rpx;
  color: #666;
}

.review-option.selected .review-option-text {
  font-weight: bold;
}

.reject-input {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 16rpx;
}

.reject-textarea {
  width: 100%;
  height: 160rpx;
  font-size: 26rpx;
  color: #333;
  background: transparent;
}

.reject-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
}

.btn-cancel {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
}

.btn-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #FF6B9D, #FF8FA3);
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
}
