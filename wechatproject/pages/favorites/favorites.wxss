.page {
  min-height: 100vh;
  background: var(--bg);
}

.stats-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx;
}

.stats-icon { font-size: 36rpx; }

.stats-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.highlight {
  color: var(--primary);
  font-weight: 700;
}

/* 收藏卡片 */
.fav-list {
  padding: 0 28rpx;
}

.fav-card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.fav-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.fav-user {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.fav-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #FF6B9D, #A78BFA);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.fav-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.fav-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

.fav-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.fav-hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.fav-btn {
  font-size: 22rpx;
  color: var(--danger);
  padding: 8rpx 24rpx;
  border: 2rpx solid var(--danger);
  border-radius: 24rpx;
  font-weight: 500;
}

.card-hover {
  transform: scale(0.98);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 48rpx;
}

.empty-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #FDF2F8;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.empty-icon { font-size: 64rpx; }
.empty-text { font-size: 32rpx; font-weight: 700; color: var(--text); margin-bottom: 8rpx; }
.empty-hint { font-size: 24rpx; color: var(--text-tertiary); text-align: center; margin-bottom: 36rpx; }

.empty-btn {
  background: linear-gradient(135deg, #FF6B9D, #A78BFA);
  color: #fff;
  padding: 22rpx 72rpx;
  border-radius: var(--radius-xl);
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(255,107,157,0.3);
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
}
