<view class="container">
  <view class="user-card" bindtap="onLogin">
    <view class="avatar" catchtap="onAvatarTap">
      <image class="avatar-img" wx:if="{{user.avatarLocal || user.avatarFull || user.avatar}}" src="{{user.avatarLocal || user.avatarFull || user.avatar}}" mode="aspectFill"></image>
      <text class="avatar-text" wx:else>{{user.avatarLetter || '?'}}</text>
      <view class="avatar-edit-hint" wx:if="{{isLoggedIn}}">编辑</view>
    </view>
    <view class="user-info">
      <text class="nickname">{{user.nickname || '点击登录'}}</text>
      <view class="credit-row" wx:if="{{isLoggedIn}}">
        <view class="credit-badge">
          <text class="credit-score">{{user.creditScore}}</text>
          <text class="credit-label">信用分</text>
        </view>
        <view class="credit-badge">
          <text class="credit-score">Lv.{{user.creditLevel}}</text>
          <text class="credit-label">等级</text>
        </view>
        <view class="credit-badge">
          <text class="credit-score">{{user.successTransactions}}/{{user.totalTransactions}}</text>
          <text class="credit-label">成功/总交易</text>
        </view>
      </view>
      <text class="login-hint" wx:else>登录后享受更多功能</text>
    </view>
    <text class="arrow" wx:if="{{!isLoggedIn}}">></text>
  </view>

  <view class="info-section" wx:if="{{isLoggedIn}}">
    <view class="section-title">基本信息</view>
    <view class="info-card">
      <view class="info-item" bindtap="onEditNickname">
        <text class="info-label">昵称</text>
        <view class="info-value-wrap">
          <text class="info-value">{{user.nickname || '未设置'}}</text>
          <text class="info-arrow">></text>
        </view>
      </view>
      <view class="info-item" bindtap="onEditPhone">
        <text class="info-label">手机号</text>
        <view class="info-value-wrap">
          <text class="info-value">{{user.phone || '未绑定'}}</text>
          <text class="info-arrow">></text>
        </view>
      </view>
      <view class="info-item" bindtap="onEditRealName">
        <text class="info-label">真实姓名</text>
        <view class="info-value-wrap">
          <text class="info-value">{{user.realName || '未设置'}}</text>
          <text class="info-arrow">></text>
        </view>
      </view>
    </view>
  </view>

  <view class="info-section" wx:if="{{isLoggedIn}}">
    <view class="section-title">偏好设置</view>
    <view class="info-card">
      <view class="info-item" bindtap="onEditPreference" data-field="preferredArtists">
        <text class="info-label">偏好艺人</text>
        <view class="info-value-wrap">
          <text class="info-value">{{preference.preferredArtists || '未设置'}}</text>
          <text class="info-arrow">></text>
        </view>
      </view>
      <view class="info-item" bindtap="onEditPreference" data-field="preferredVersions">
        <text class="info-label">偏好版本</text>
        <view class="info-value-wrap">
          <text class="info-value">{{preference.preferredVersions || '未设置'}}</text>
          <text class="info-arrow">></text>
        </view>
      </view>
      <view class="info-item" bindtap="onEditPreference" data-field="preferredCards">
        <text class="info-label">偏好小卡</text>
        <view class="info-value-wrap">
          <text class="info-value">{{preference.preferredCards || '未设置'}}</text>
          <text class="info-arrow">></text>
        </view>
      </view>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" wx:for="{{menuList}}" wx:key="text" bindtap="onMenuTap" data-item="{{item}}">
      <view class="menu-left">
        <view class="menu-icon-round" style="background: {{item.color}}22">
          <text class="menu-icon-emoji">{{item.icon}}</text>
        </view>
        <text class="menu-text">{{item.text}}</text>
      </view>
      <view class="menu-right">
        <text class="unread-badge-num" wx:if="{{item.text === '消息通知' && unreadCount > 0}}">{{unreadCount > 99 ? '99+' : unreadCount}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="logout-section" wx:if="{{isLoggedIn}}">
    <button class="btn-danger logout-btn" bindtap="onLogout">退出登录</button>
  </view>

  <view class="bottom">
    <text class="copyright">拼车协作平台 v1.0.0</text>
  </view>
</view>
