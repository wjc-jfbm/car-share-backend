<view class="container">
  <view class="login-card">
    <view class="logo-area">
      <view class="logo">
        <image class="logo-img" src="/images/logo.png" mode="aspectFit" />
      </view>
      <text class="app-name">拼车协作平台</text>
      <text class="app-desc">面向粉丝团购场景的拼车协作与可信结算</text>
    </view>

    <view class="mode-tabs">
      <view class="mode-tab {{loginMode === 'wechat' ? 'active' : ''}}" bindtap="onModeSwitch" data-mode="wechat">
        <text>微信登录</text>
      </view>
      <view class="mode-tab {{loginMode === 'account' ? 'active' : ''}}" bindtap="onModeSwitch" data-mode="account">
        <text>账号登录</text>
      </view>
    </view>

    <view class="login-content" wx:if="{{loginMode === 'wechat'}}">
      <view class="wechat-login-area">
        <button class="btn-wechat" bindtap="onWechatLogin" loading="{{isLoading}}" disabled="{{isLoading}}">
          微信一键登录
        </button>
        <text class="wechat-hint">使用微信身份快速登录</text>
      </view>
    </view>

    <view class="login-content" wx:if="{{loginMode === 'account'}}">
      <view class="account-login-area">
        <view class="sub-tabs" wx:if="{{!isRegister}}">
          <text class="sub-tab active">登录</text>
          <text class="sub-tab-link" bindtap="onSwitchRegister">去注册</text>
        </view>
        <view class="sub-tabs" wx:if="{{isRegister}}">
          <text class="sub-tab active">注册</text>
          <text class="sub-tab-link" bindtap="onSwitchLogin">去登录</text>
        </view>

        <view class="input-group">
          <view class="input-row">
            <image class="input-icon-img" src="/images/user-gray.png" mode="aspectFit" />
            <input class="input-field" type="text" maxlength="11" placeholder="请输入手机号" value="{{username}}" bindinput="onUsernameInput" />
          </view>
        </view>

        <view class="input-group" wx:if="{{isRegister}}">
          <view class="input-row">
            <image class="input-icon-img" src="/images/star-gray.png" mode="aspectFit" />
            <input class="input-field" type="text" maxlength="20" placeholder="请输入昵称（选填）" value="{{nickname}}" bindinput="onNicknameInput" />
          </view>
        </view>

        <view class="input-group">
          <view class="input-row">
            <image class="input-icon-img" src="/images/shield-gray.png" mode="aspectFit" />
            <input class="input-field" password="{{!showPassword}}" maxlength="20" placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" />
            <text class="toggle-pwd" bindtap="onTogglePassword">{{showPassword ? '隐藏' : '显示'}}</text>
          </view>
        </view>

        <view class="input-group" wx:if="{{isRegister}}">
          <view class="input-row">
            <image class="input-icon-img" src="/images/shield-gray.png" mode="aspectFit" />
            <input class="input-field" password="{{true}}" maxlength="20" placeholder="请确认密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
          </view>
        </view>

        <button class="btn-account" bindtap="onAccountSubmit" loading="{{isLoading}}" disabled="{{isLoading || !username || !password || (isRegister && !confirmPassword)}}">
          {{isRegister ? '注册' : '登录'}}
        </button>

        <text class="account-hint" wx:if="{{!isRegister}}">还没有账号？<text class="link" bindtap="onSwitchRegister">立即注册</text></text>
        <text class="account-hint" wx:if="{{isRegister}}">已有账号？<text class="link" bindtap="onSwitchLogin">去登录</text></text>
      </view>
    </view>

    <view class="agreement-area">
      <text class="agreement">登录即代表同意<text class="link">《用户协议》</text>和<text class="link">《隐私政策》</text></text>
    </view>

    <view class="back-btn" bindtap="onBack">
      <text>暂不登录</text>
    </view>
  </view>
</view>
