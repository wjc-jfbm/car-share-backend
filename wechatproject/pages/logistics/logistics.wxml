<view class="container">
  <view class="logistics-header">
    <view class="header-info">
      <text class="header-title">{{car.title || '物流追踪'}}</text>
      <text class="header-sub" wx:if="{{logisticsList.length > 0}}">共 {{logisticsList.length}} 个包裹</text>
    </view>
    <button class="btn-ship" wx:if="{{isOwner}}" bindtap="onShowCreateModal">录入发货</button>
  </view>

  <view class="logistics-list" wx:if="{{logisticsList.length > 0}}">
    <view class="package-card" wx:for="{{logisticsList}}" wx:key="id">
      <view class="package-header">
        <view class="package-status" style="background: {{statusMap[item.status].color}}15;">
          <text class="status-icon">{{statusMap[item.status].icon}}</text>
          <text class="status-text" style="color: {{statusMap[item.status].color}};">{{statusMap[item.status].text}}</text>
        </view>
        <text class="package-company">{{item.express_company || '未知快递'}}</text>
      </view>

      <view class="package-info">
        <view class="info-row">
          <text class="info-label">快递单号</text>
          <view class="info-value-row">
            <text class="info-value">{{item.express_no || '暂无'}}</text>
            <text class="copy-btn" wx:if="{{item.express_no}}" bindtap="onCopyExpressNo" data-no="{{item.express_no}}">复制</text>
          </view>
        </view>
        <view class="info-row" wx:if="{{item.receiver_name}}">
          <text class="info-label">收件人</text>
          <text class="info-value">{{item.receiver_name}}</text>
        </view>
        <view class="info-row" wx:if="{{item.receiver_phone}}">
          <text class="info-label">联系电话</text>
          <view class="info-value-row">
            <text class="info-value">{{item.receiver_phone}}</text>
            <text class="call-btn" bindtap="onCallReceiver" data-phone="{{item.receiver_phone}}">拨打</text>
          </view>
        </view>
        <view class="info-row" wx:if="{{item.receiver_address}}">
          <text class="info-label">收货地址</text>
          <text class="info-value address">{{item.receiver_address}}</text>
        </view>
      </view>

      <view class="package-timeline" wx:if="{{item.nodes.length > 0}}">
        <view class="timeline-title">物流轨迹</view>
        <view class="node-list">
          <view class="node-item" wx:for="{{item.nodes}}" wx:for-item="node" wx:key="time">
            <view class="node-dot {{index === 0 ? 'active' : ''}}"></view>
            <view class="node-content">
              <text class="node-desc">{{node.description}}</text>
              <text class="node-location" wx:if="{{node.location}}">{{node.location}}</text>
              <text class="node-time">{{node.time}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="package-actions">
        <button class="btn-update" wx:if="{{isOwner}}" bindtap="onShowUpdateModal" data-logistics="{{item}}">更新状态</button>
        <button class="btn-receive" wx:if="{{!isOwner && item.status >= 1 && item.status < 4}}" bindtap="onConfirmReceive" data-logistics="{{item}}">确认签收</button>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{logisticsList.length === 0}}">
    <image class="empty-img" src="/images/truck.png" mode="aspectFit" />
    <text class="empty-text" wx:if="{{isOwner}}">暂无物流信息，成团后可录入发货</text>
    <text class="empty-text" wx:else>暂无物流信息，等待车主发货</text>
    <button class="btn-ship-empty" wx:if="{{isOwner}}" bindtap="onShowCreateModal">录入发货信息</button>
  </view>

  <view class="modal-mask" wx:if="{{showCreateModal}}" bindtap="onHideCreateModal"></view>
  <view class="modal-content create-modal" wx:if="{{showCreateModal}}">
    <view class="modal-header">
      <text class="modal-title">录入发货信息</text>
      <text class="modal-close" bindtap="onHideCreateModal">&#x2715;</text>
    </view>
    <scroll-view class="modal-body" scroll-y>
      <view class="form-group">
        <text class="form-label">快递公司 <text class="required">*</text></text>
        <view class="form-picker" bindtap="onShowCompanyPicker">
          <text class="picker-value {{newLogistics.expressCompany ? '' : 'placeholder'}}">{{newLogistics.expressCompany || '请选择快递公司'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </view>

      <view class="form-group">
        <text class="form-label">快递单号 <text class="required">*</text></text>
        <input class="form-input" placeholder="请输入快递单号" value="{{newLogistics.expressNo}}" bindinput="onExpressNoInput" />
      </view>

      <view class="form-group">
        <text class="form-label">收件人信息</text>
        <view class="member-quick-select" wx:if="{{memberList.length > 0}}">
          <text class="quick-label">从成员中选择：</text>
          <text class="quick-btn" bindtap="onShowMemberSelect">{{selectedMemberIndex >= 0 ? memberList[selectedMemberIndex].nickname : '选择成员'}}</text>
        </view>
      </view>

      <view class="form-group">
        <text class="form-label">收件人 <text class="required">*</text></text>
        <input class="form-input" placeholder="收件人姓名" value="{{newLogistics.receiverName}}" bindinput="onReceiverNameInput" />
      </view>

      <view class="form-group">
        <text class="form-label">联系电话 <text class="required">*</text></text>
        <input class="form-input" placeholder="收件人手机号" type="number" maxlength="11" value="{{newLogistics.receiverPhone}}" bindinput="onReceiverPhoneInput" />
      </view>

      <view class="form-group">
        <text class="form-label">收货地址 <text class="required">*</text></text>
        <textarea class="form-textarea" placeholder="详细收货地址" value="{{newLogistics.receiverAddress}}" bindinput="onReceiverAddressInput" maxlength="200"></textarea>
      </view>

      <view class="form-group">
        <text class="form-label">备注</text>
        <input class="form-input" placeholder="备注信息（选填）" value="{{newLogistics.remark}}" bindinput="onRemarkInput" />
      </view>
    </scroll-view>
    <view class="modal-footer">
      <button class="btn-cancel" bindtap="onHideCreateModal">取消</button>
      <button class="btn-confirm" bindtap="onCreateLogistics">确认发货</button>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showUpdateModal}}" bindtap="onHideUpdateModal"></view>
  <view class="modal-content update-modal" wx:if="{{showUpdateModal && currentLogistics}}">
    <view class="modal-header">
      <text class="modal-title">更新物流状态</text>
      <text class="modal-close" bindtap="onHideUpdateModal">&#x2715;</text>
    </view>
    <view class="modal-body">
      <view class="update-info">
        <text class="update-company">{{currentLogistics.express_company}}</text>
        <text class="update-no">{{currentLogistics.express_no}}</text>
        <text class="update-current">当前状态：{{statusMap[currentLogistics.status].text}}</text>
      </view>
      <view class="status-options">
        <view class="status-option" wx:for="{{statusMap}}" wx:key="index" bindtap="onUpdateStatus" data-status="{{index}}">
          <text class="status-option-icon">{{item.icon}}</text>
          <text class="status-option-text">{{item.text}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showCompanyPicker}}" bindtap="onHideCompanyPicker"></view>
  <view class="picker-modal" wx:if="{{showCompanyPicker}}">
    <view class="picker-header">
      <text class="picker-title">选择快递公司</text>
      <text class="picker-close" bindtap="onHideCompanyPicker">&#x2715;</text>
    </view>
    <scroll-view class="picker-list" scroll-y>
      <view class="picker-item {{selectedCompanyIndex === index ? 'selected' : ''}}" wx:for="{{expressCompanies}}" wx:key="code" bindtap="onCompanySelect" data-index="{{index}}">
        <text class="picker-item-name">{{item.name}}</text>
        <text class="picker-item-check" wx:if="{{selectedCompanyIndex === index}}">&#x2713;</text>
      </view>
    </scroll-view>
  </view>

  <view class="modal-mask" wx:if="{{showMemberSelect}}" bindtap="onHideMemberSelect"></view>
  <view class="picker-modal" wx:if="{{showMemberSelect}}">
    <view class="picker-header">
      <text class="picker-title">选择成员</text>
      <text class="picker-close" bindtap="onHideMemberSelect">&#x2715;</text>
    </view>
    <scroll-view class="picker-list" scroll-y>
      <view class="picker-item {{selectedMemberIndex === index ? 'selected' : ''}}" wx:for="{{memberList}}" wx:key="user_id" bindtap="onMemberSelect" data-index="{{index}}">
        <text class="picker-item-name">{{item.nickname || '用户'}}</text>
        <text class="picker-item-check" wx:if="{{selectedMemberIndex === index}}">&#x2713;</text>
      </view>
    </scroll-view>
  </view>
</view>
