.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.logistics-header {
  background: linear-gradient(135deg, #2196F3, #42A5F5);
  padding: 32rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-info {
  flex: 1;
}

.header-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 8rpx;
}

.header-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.btn-ship {
  padding: 16rpx 32rpx;
  background: white;
  color: #2196F3;
  font-size: 26rpx;
  font-weight: bold;
  border-radius: 32rpx;
  border: none;
  line-height: 1.2;
}

.logistics-list {
  padding: 16rpx 24rpx;
}

.package-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.package-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.package-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.status-icon {
  font-size: 28rpx;
}

.status-text {
  font-size: 26rpx;
  font-weight: bold;
}

.package-company {
  font-size: 26rpx;
  color: #666;
}

.package-info {
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 10rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
  width: 140rpx;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  text-align: right;
  word-break: break-all;
}

.info-value.address {
  line-height: 1.5;
}

.info-value-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  justify-content: flex-end;
}

.copy-btn {
  font-size: 22rpx;
  color: #2196F3;
  padding: 4rpx 12rpx;
  border: 1rpx solid #2196F3;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.call-btn {
  font-size: 22rpx;
  color: #4CAF50;
  padding: 4rpx 12rpx;
  border: 1rpx solid #4CAF50;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.package-timeline {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.timeline-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.node-list {
  padding-left: 24rpx;
  border-left: 4rpx solid #e0e0e0;
  margin-left: 8rpx;
}

.node-item {
  position: relative;
  padding: 12rpx 0 12rpx 28rpx;
}

.node-dot {
  position: absolute;
  left: -28rpx;
  top: 20rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ddd;
  border: 4rpx solid white;
}

.node-dot.active {
  background: #2196F3;
  box-shadow: 0 0 0 6rpx rgba(33, 150, 243, 0.2);
}

.node-content {
  background: #f8f8f8;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
}

.node-desc {
  display: block;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.node-location {
  display: block;
  font-size: 22rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.node-time {
  display: block;
  font-size: 20rpx;
  color: #999;
}

.package-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-update {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  background: #e3f2fd;
  color: #2196F3;
  font-size: 26rpx;
  font-weight: bold;
  border-radius: 32rpx;
  border: none;
}

.btn-receive {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: white;
  font-size: 26rpx;
  font-weight: bold;
  border-radius: 32rpx;
  border: none;
}

.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-img {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.btn-ship-empty {
  width: 280rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #2196F3, #42A5F5);
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 36rpx;
  border: none;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.modal-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 201;
  max-height: 85vh;
}

.create-modal {
  padding: 32rpx 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx;
}

.modal-body {
  margin-bottom: 24rpx;
}

.create-modal .modal-body {
  max-height: 55vh;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.required {
  color: #F44336;
}

.form-input {
  width: 100%;
  height: 72rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 120rpx;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 72rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.picker-value {
  font-size: 26rpx;
  color: #333;
}

.picker-value.placeholder {
  color: #999;
}

.picker-arrow {
  font-size: 32rpx;
  color: #999;
}

.member-quick-select {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  background: #e3f2fd;
  border-radius: 8rpx;
}

.quick-label {
  font-size: 24rpx;
  color: #666;
}

.quick-btn {
  font-size: 24rpx;
  color: #2196F3;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border: 1rpx solid #2196F3;
  border-radius: 8rpx;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
}

.btn-cancel {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
}

.btn-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #2196F3, #42A5F5);
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
}

.update-modal {
  padding: 32rpx 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.update-info {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.update-company {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.update-no {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.update-current {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.status-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.status-option {
  width: calc(33.33% - 12rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 0;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.status-option:active {
  background: #e3f2fd;
  border-color: #2196F3;
}

.status-option-icon {
  font-size: 36rpx;
}

.status-option-text {
  font-size: 22rpx;
  color: #666;
}

.picker-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 300;
  max-height: 60vh;
  padding-bottom: env(safe-area-inset-bottom);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.picker-close {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx;
}

.picker-list {
  max-height: 50vh;
  padding: 8rpx 0;
}

.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.picker-item.selected {
  background: #e3f2fd;
}

.picker-item-name {
  font-size: 28rpx;
  color: #333;
}

.picker-item.selected .picker-item-name {
  color: #2196F3;
  font-weight: bold;
}

.picker-item-check {
  font-size: 28rpx;
  color: #2196F3;
  font-weight: bold;
}
