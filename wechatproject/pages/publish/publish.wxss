.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.form-section {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 16rpx 24rpx;
}

.form-section .section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #FF6B9D;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-item .label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.form-item .label .required {
  color: #f44336;
  margin-left: 4rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #eee;
}

.input:focus {
  border-color: #FF6B9D;
  background: white;
}

.textarea {
  width: 100%;
  height: 200rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #eee;
}

.textarea:focus {
  border-color: #FF6B9D;
  background: white;
}

.calculated-price {
  display: flex;
  align-items: baseline;
  padding: 16rpx 0;
}

.calculated-price .price-value {
  font-size: 40rpx;
  color: #FF6B9D;
  font-weight: bold;
  margin-right: 8rpx;
}

.calculated-price .hint {
  font-size: 22rpx;
  color: #999;
}

.radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.radio-item radio {
  margin-right: 8rpx;
}

.picker-value {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #eee;
}

.picker-value.placeholder {
  color: #999;
}

.form-actions {
  padding: 32rpx 24rpx;
}

.form-actions .btn-primary {
  width: 100%;
  padding: 24rpx 0;
  font-size: 32rpx;
}

.image-upload-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.image-preview {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-preview .preview-img {
  width: 100%;
  height: 100%;
}

.image-preview .image-remove {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: white;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 12rpx 0 12rpx;
}

.image-add {
  width: 160rpx;
  height: 160rpx;
  background: #f8f8f8;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.image-add .add-icon {
  font-size: 48rpx;
  color: #ccc;
  line-height: 1;
}

.image-add .add-icon-img {
  width: 48rpx;
  height: 48rpx;
  opacity: 0.4;
}

.image-add .add-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.form-tip {
  background: #FFF8E1;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  margin-top: 16rpx;
}

.form-tip text {
  font-size: 24rpx;
  color: #FF9800;
}

/* ====== 模板相关 ====== */
.template-bar {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FDF2F8, #F3F0FF);
  border: 2rpx solid #F3F0FF;
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  margin: 16rpx 24rpx 0;
  gap: 12rpx;
}

.template-bar-icon {
  font-size: 32rpx;
}

.template-bar-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--secondary);
  font-weight: 500;
}

.template-bar-arrow {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.template-list {
  margin: 0 24rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.template-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 2rpx solid var(--border);
}

.template-item:last-child {
  border-bottom: none;
}

.template-item-left {
  flex: 1;
}

.template-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  display: block;
}

.template-desc {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 6rpx;
  display: block;
}

.template-use {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 600;
  padding: 8rpx 24rpx;
  border: 2rpx solid var(--primary);
  border-radius: 24rpx;
}

/* 切换开关 */
.toggle-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 0;
}

.toggle-track {
  width: 80rpx;
  height: 44rpx;
  background: #E5E7EB;
  border-radius: 22rpx;
  position: relative;
  transition: background 0.2s;
}

.toggle-track.on {
  background: linear-gradient(135deg, #FF6B9D, #A78BFA);
}

.toggle-thumb {
  width: 36rpx;
  height: 36rpx;
  background: #fff;
  border-radius: 50%;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.15);
  transition: left 0.2s;
}

.toggle-track.on .toggle-thumb {
  left: 40rpx;
}

.toggle-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.template-save-section {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin: 16rpx 24rpx;
}
